{
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check main.ts vite.config.ts src/**/*.ts routes/**/*.ts",
    "dev": "deno run -A --watch main.ts",
    "test": "deno test -A",
    "start": "deno run -A main.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "$fresh/": "jsr:@fresh/core@^2.0.0-alpha.29/",
    "preact": "npm:preact@^10.26.9",
    "preact/": "npm:preact@^10.26.9/",
    "@preact/signals": "npm:@preact/signals@^2.0.1",
    "@preact/signals-core": "npm:@preact/signals-core@^1.8.0",
    "vite": "npm:vite@^6.3.5"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "deno.unstable"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "deploy": {
    "install": "deno install",
    "build": "echo 'no build step'",
    "runtime": {
      "type": "dynamic",
      "entrypoint": "main.ts"
    }
  }
}
